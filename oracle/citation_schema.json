{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OracleCitation",
  "type": "object",
  "required": [
    "claim_id",
    "work_id",
    "version_id",
    "title",
    "source",
    "source_url",
    "locator",
    "confidence"
  ],
  "properties": {
    "claim_id": {
      "type": "string"
    },
    "chunk_id": {
      "type": ["string", "null"]
    },
    "doc_id": {
      "type": ["string", "null"]
    },
    "work_id": {
      "type": "string"
    },
    "version_id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "author": {
      "type": ["string", "null"]
    },
    "translator": {
      "type": ["string", "null"]
    },
    "source": {
      "type": "string"
    },
    "source_id": {
      "type": ["string", "null"]
    },
    "source_url": {
      "type": ["string", "null"]
    },
    "license_status": {
      "type": ["string", "null"]
    },
    "quality_tier": {
      "type": ["string", "null"]
    },
    "ocr_quality_class": {
      "type": ["string", "null"]
    },
    "locator": {
      "type": "object",
      "properties": {
        "hierarchy": {
          "type": ["object", "null"]
        },
        "offsets": {
          "type": ["object", "null"]
        },
        "page": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
